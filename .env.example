# Supabase project URL, e.g. https://xyzcompany.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# Supabase public anon key from Project Settings -> API
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Supabase service role key (server-only) for webhook tier sync
SUPABASE_SERVICE_ROLE_KEY=
# OAuth provider flags for login buttons
NEXT_PUBLIC_AUTH_GOOGLE_ENABLED=true
NEXT_PUBLIC_AUTH_APPLE_ENABLED=false
# Stripe (server-only)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_MONTHLY_PRICE_ID=
# Optional founder promo code shown in UI copy
NEXT_PUBLIC_STRIPE_FOUNDER_PROMO_CODE=FOUNDER100
# App base URL for Stripe return paths
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000
# OpenAI API key (server-only) for Race Engineer and RAG index build
OPENAI_API_KEY=
# Chat model for Race Engineer
AI_MODEL=gpt-4o-mini
# Embedding model for the RAG index (must match what rag:index was built with)
AI_EMBEDDING_MODEL=text-embedding-3-small
# Per-user hourly request limit for Race Engineer
AI_RATE_LIMIT_PER_HOUR=20
# Per-user per-minute burst limit for Race Engineer
AI_RATE_LIMIT_PER_MINUTE=3
